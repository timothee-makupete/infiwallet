# Shared secrets (use strong values in production)
JWT_SECRET=change-me-to-a-long-random-string
INTERNAL_API_KEY=change-me-internal-service-key

# PostgreSQL (single DB; each service uses its own schema via DATABASE_URL)
DATABASE_URL_BASE=postgresql://infiwallet:infiwallet_dev@localhost:5432/infiwallet

USER_DATABASE_URL=postgresql://infiwallet:infiwallet_dev@localhost:5432/infiwallet?schema=user_management
WALLET_DATABASE_URL=postgresql://infiwallet:infiwallet_dev@localhost:5432/infiwallet?schema=wallet
KYC_DATABASE_URL=postgresql://infiwallet:infiwallet_dev@localhost:5432/infiwallet?schema=kyc

REDIS_URL=redis://localhost:6379
RABBITMQ_URL=amqp://infiwallet:infiwallet_dev@localhost:5672

# Service ports (development)
USER_SERVICE_PORT=3001
WALLET_SERVICE_PORT=3002
KYC_SERVICE_PORT=3003
API_GATEWAY_PORT=3018

USER_SERVICE_URL=http://localhost:3001
# user-service calls this to create a wallet on register (with INTERNAL_API_KEY)
WALLET_SERVICE_URL=http://localhost:3002
KYC_SERVICE_URL=http://localhost:3003

# Next.js apps
NEXT_PUBLIC_API_URL=http://localhost:3018

# Seed admin (user-service prisma seed)
SEED_ADMIN_EMAIL=admin@infiwallet.local
SEED_ADMIN_PASSWORD=Admin123456!
